# 🎭 Parody Critics - Environment Configuration
# Copy this file to .env and fill in your values

# ── Server ──────────────────────────────────────────────
PARODY_CRITICS_ENV=development
PARODY_CRITICS_HOST=0.0.0.0
PARODY_CRITICS_PORT=8000
PARODY_CRITICS_DB_PATH=database/critics.db

# ── Jellyfin ─────────────────────────────────────────────
JELLYFIN_URL=http://your-jellyfin-host:8096
JELLYFIN_API_TOKEN=your-jellyfin-api-token-here
JELLYFIN_DB_PATH=/path/to/jellyfin/library.db

# ── LLM (Ollama) ─────────────────────────────────────────
LLM_OLLAMA_URL=http://your-ollama-host:11434
LLM_PRIMARY_MODEL=mistral-small3.1:24b
LLM_SECONDARY_MODEL=type32/eva-qwen-2.5-14b:latest
LLM_TIMEOUT=180
LLM_MAX_RETRIES=2
LLM_ENABLE_FALLBACK=true

# ── Enrichment APIs ───────────────────────────────────────
# TMDB: https://www.themoviedb.org/settings/api  (use "API Read Access Token")
TMDB_ACCESS_TOKEN=your-tmdb-read-access-token-here

# Brave Search: https://api.search.brave.com/  (free tier: 2000 req/month)
BRAVE_API_KEY=your-brave-api-key-here

# ── Sync ─────────────────────────────────────────────────
SYNC_BATCH_SIZE=100
SYNC_MAX_CONCURRENT=5

# ── Cache / Performance ───────────────────────────────────
PARODY_CRITICS_CACHE_DURATION=300
PARODY_CRITICS_LOG_LEVEL=INFO
